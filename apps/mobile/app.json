{
  "expo": {
    "scheme": "futoride",
    "name": "Futo Ride",
    "slug": "futo-ride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff445"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.anonymous.futoride",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKeyPlaceholder___FutoRideTestingKey"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to attach receipts.",
          "cameraPermission": "The app needs access to your camera to take receipt photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Grant permission to save photos to your gallery.",
          "savePhotosPermission": "Grant permission to save photos to your gallery."
        }
      ],
      [
        "react-native-maps",
        {
          "isAndroidLocationServicesEnabled": true
        }
      ]
    ]
  }
}