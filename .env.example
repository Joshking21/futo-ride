# Environment variables — NAMES + COMMENTS ONLY. Never commit real values.
# NEXT_PUBLIC_* is exposed to the client; everything else is server-only secret.
# Confirm names as features land (AGENTS.md §8).

# Firebase (client — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=     # Realtime DB (live positions)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server — SECRET)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Monnify (server — SECRET) — sandbox vs live via base URL
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=                      # sandbox.monnify.com vs api.monnify.com

# Alerta (server — SECRET)
ALERTA_API_KEY=
ALERTA_API_SECRET=
ALERTA_TELEGRAM_TARGET=                # SUG security group identifier

# LLM / AI triage (server — SECRET)
LLM_API_KEY=

# Google Maps (client) — needs a billing account attached
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
