# Environment variables — NAMES + COMMENTS ONLY. Never commit real values.
# Server-side only, read in apps/api. Confirm names as features land (AGENTS.md §8).

# Firebase Admin (server — SECRET)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Payment provider (server) — which rail /payments/* runs on. partna | paj (default paj).
PAYMENT_PROVIDER=                      # default "paj"

# Partna (server — SECRET) — NGN collection (onramp → USDC treasury) + payout (offramp). (§21)
# Auth is x-api-key + x-api-user headers (no request signing). Verified: docs.getpartna.com/v4.
PARTNA_API_KEY=                        # from the Partna dashboard (staging vs prod keys differ)
PARTNA_API_USER=                       # merchant username (also the widget `merchant` param)
PARTNA_BASE_URL=                       # default https://staging-api.getpartna.com/v4 ; prod https://api.getpartna.com/v4
PARTNA_PAY_URL=                        # hosted widget host; default https://staging-pay.getpartna.com ; prod https://pay.getpartna.com
PARTNA_WEBHOOK_PUBLIC_KEY=             # Partna's env-specific RSA PUBLIC key (PEM) — verifies webhook signatures (RSA-PSS/SHA-256 over data)

# PAJ Ramp (server — SECRET) — alt NGN collection provider (onramp → USDC treasury). npm: paj_ramp.
# Auth = a platform session token (Bearer), obtained once via OTP (see apps/api/src/scripts/paj-smoke.ts).
PAJ_API_KEY=                           # PAJ business key (x-api-key) — used by the smoke-script OTP flow
PAJ_ENV=                               # staging | production | local (default production; the issued key is env-specific)
PAJ_SESSION_TOKEN=                     # platform Bearer token (~2yr) from verify(); falls back to apps/api/.paj-session.json in dev
PAJ_WEBHOOK_SECRET=                    # expected value of the webhook's `Authorization: Bearer <secret>` header
PAYMENTS_WEBHOOK_URL=                  # REQUIRED for paj: public https URL of POST /payments/webhook (PAJ posts status here)
PAJ_USDC_MINT=                         # optional; default mainnet USDC EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

TREASURY_SOLANA_ADDRESS=              # platform Solana wallet that receives onramp USDC (the treasury) — MUST have an initialized USDC ATA

# Driver onboarding (server) — whitelist gate for POST /drivers/register (§20.6)
DRIVER_WHITELIST=                      # comma-separated approved driver emails; empty = use allowedDrivers Firestore collection instead

# Alerta (server — SECRET)
ALERTA_API_KEY=
ALERTA_API_SECRET=
ALERTA_TELEGRAM_TARGET=                # Alerta channelRef for the SUG group (format TG_ALT_xxxxx, from Alerta dashboard → Channels — NOT the raw Telegram chat id)

# Telegram bot (server — SECRET) — captures per-user chat ids via /start
TELEGRAM_BOT_TOKEN=                    # BotFather token
TELEGRAM_WEBHOOK_SECRET=               # random string; echoed in setWebhook + verified on each call (Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")

# LLM / AI triage (server — SECRET)
LLM_API_KEY=
LLM_MODEL=                             # optional, defaults to gemini-3.5-flash

# Lifecycle tunables (server — optional; sensible defaults in code) (§20/§21)
PAYMENT_WINDOW_MS=                     # seat hold before an unpaid ride expires (default 600000 = 10 min; bank transfers are slower than cards)
DRIVER_HEARTBEAT_MS=                   # driver silent longer than this = not matchable (default 120000 = 2 min)
SURGE_GRACE_MS=                        # honor an opted-in priorityFee this long after surge flips off (default 60000)
PRIORITY_FEE_CAP_KOBO=                 # max accepted priorityFee (default 500000 = ₦5000)
PLATFORM_FEE_BPS=                      # platform cut of the seat fare in basis points (default 500 = 5%; driver keeps the rest) (§21/P2)
CANCELLATION_FEE_KOBO=                 # fee if a rider cancels while the driver is en route (default 5000 = ₦50) (§21/H4)

# Solana welfare vault (server — devnet) — on-chain treasury PDA (todo.md S2/S4).
# Optional: if VAULT_USDC_MINT + VAULT_AUTHORITY_SECRET_KEY are unset the backend skips the
# on-chain leg entirely (the naira/ledger flow is unaffected). Program id + PDAs are derived
# from the vendored IDL (apps/api/src/lib/vault-idl.ts). Set up via apps/vault `npm run init:devnet`.
SOLANA_RPC_URL=                        # default https://api.devnet.solana.com
VAULT_USDC_MINT=                       # the vault's USDC mint (devnet test mint from init:devnet)
VAULT_AUTHORITY_SECRET_KEY=            # SECRET — JSON array of the 64-byte authority secret key (contents of ~/.config/solana/id.json)
# NOTE: no static FX rate. The vault contribution is sized at the LIVE rate the rider settled at
# (PAJ `rate`, stored as payment.paidRate). If that rate is absent the on-chain leg is skipped.

# Server
PORT=

# Development
ENABLE_PAYMENT_BYPASS=                 # set to "true" to enable the POST /payments/bypass endpoint without going through Partna
